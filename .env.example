# fdi_office_automation environment configuration
# Copy this file to .env and set SYNC_ROOT for your machine.
# All other paths are derived from SYNC_ROOT automatically.

# ── Sync root ────────────────────────────────────────────────────────────────
# Root of the sync.com FdI folder on this machine.
# macOS:   /Users/<you>/Sync/FdI
# Linux:   /home/<you>/Sync/FdI
# WSL2:    /mnt/c/Users/<you>/Sync/FdI
SYNC_ROOT=/Users/yourname/Sync/FdI

# ── Derived paths (override only if your layout differs) ─────────────────────
# SIG_BASE defaults to $SYNC_ROOT/SIG
# SIG_BASE=/Users/yourname/Sync/FdI/SIG

# Predios input/archive folders
# PREDIOS_FOLDER=$SIG_BASE/Estrutura Projeto Template/_Predios
# PREDIOS_ARCHIVE_FOLDER=$SIG_BASE/Estrutura Projeto Template/predios_archive

# Master property layer
# LIMITE_PROPRIEDADE_GPKG=$SIG_BASE/Estrutura Projeto Template/VectorData/Limite da Propriedade.gpkg

# OSM data paths
# REGIONAL_DEM_PATH=$SIG_BASE/shared_inputs/raster_data/topography/regional_elevation.tif
# OSM_DATA_DIR=$SIG_BASE/shared_inputs/vector_data/OSM

# QField cloud base (macOS only — where QField Desktop syncs to)
# QFIELD_CLOUD_BASE=/Users/yourname/QField/cloud

# ── Docker container names ────────────────────────────────────────────────────
DOCKER_CONTAINER_COMERCIAL=qgis-comercial-processor
DOCKER_CONTAINER_PHASE1=qgis-py-phase1
DOCKER_CONTAINER_PHASE2=qgis-py-phase2
DOCKER_EXEC_TIMEOUT=7200

# ── SNIRH ────────────────────────────────────────────────────────────────────
SNIRH_YEARS_BACK=5
# SNIRH_CACHE_DIR=$SIG_BASE/shared_inputs/snirh_cache

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_DIR=./logs

# ── QFieldCloud API ───────────────────────────────────────────────────────────
QFIELDCLOUD_URL=https://app.qfield.cloud/api/v1/
QFIELDCLOUD_TOKEN=your_token_here
# QFIELDCLOUD_PROJECTS={"ProjectName": "uuid", ...}

# ── Notifications ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=your@email.com
ALERT_ON_CONFLICTS=true
